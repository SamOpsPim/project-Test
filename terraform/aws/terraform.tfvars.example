aws_region        = "eu-west-1"
project_name      = "cloud-anomaly-lab"
instance_type     = "t3.micro"
environment       = "lab"
owner             = "your-team-or-handle"
cost_center       = "engineering"
application       = "cloud-anomaly-lab"
# Replace with your public IP (/32). SSH and app can differ if needed.
ssh_cidr_blocks   = ["203.0.113.10/32"]
app_cidr_blocks   = ["203.0.113.10/32"]
public_key        = "ssh-ed25519 AAAA... your-public-key"
