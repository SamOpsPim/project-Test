aws_region      = "eu-west-1"
project_name    = "cloud-anomaly-lab"
instance_type   = "t3.micro"
ssh_cidr_blocks = ["198.51.100.10/32"] # replace with your office/VPN CIDRs; 0.0.0.0/0 is rejected
# app_cidr_blocks = ["198.51.100.0/24"] # optional; defaults to ssh_cidr_blocks
environment     = "lab"
owner           = "team@example.com"
cost_center     = "engineering"
public_key      = "ssh-ed25519 AAAA... your-public-key"
