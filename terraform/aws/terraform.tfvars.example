aws_region        = "eu-west-1"
project_name      = "cloud-anomaly-lab"
instance_type     = "t3.micro"
ssh_cidr_blocks   = ["203.0.113.10/32"] # replace with your public IP /32 or trusted CIDRs (never 0.0.0.0/0)
public_key        = "ssh-ed25519 AAAA... your-public-key"

cost_allocation_tags = {
  environment = "lab"
  owner       = "team@example.com"
  project     = "cloud-anomaly-lab"
  cost_center = "engineering"
}
