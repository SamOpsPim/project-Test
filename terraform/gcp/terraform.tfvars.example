gcp_project_id    = "my-gcp-project-id"
gcp_region        = "europe-west1"
gcp_zone          = "europe-west1-b"
project_name      = "cloud-anomaly-lab"
machine_type      = "e2-micro"
ssh_user          = "ubuntu"
ssh_public_key    = "ssh-ed25519 AAAA... your-public-key"
# Required: your VPN or admin IPs only (never 0.0.0.0/0 for production).
app_source_ranges = ["203.0.113.10/32"]
ssh_source_ranges = ["203.0.113.10/32"]
environment       = "lab"
owner             = "platform"
cost_center       = "engineering"
