location                = "westeurope"
project_name            = "cloud-anomaly-lab"
vm_size                 = "Standard_B1s"
admin_username          = "azureuser"
ssh_public_key          = "ssh-ed25519 AAAA... your-public-key"
trusted_ingress_cidrs   = ["203.0.113.10/32"] # replace with your public IP or trusted range

# Set true only when you intend to create billable Azure resources
lab_enabled = true

# Optional FinOps tags
# environment = "lab"
# owner       = "team-name"
# cost_center = "engineering"
# application = "cloud-anomaly-lab"
